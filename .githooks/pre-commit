#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

if ! uv run ruff format --check . >/dev/null 2>&1; then
  echo "pre-commit: formatting issues found — run 'uv run ruff format .' and re-stage" >&2
  uv run ruff format --check . >&2 || true
  exit 1
fi

uv run ruff check .
