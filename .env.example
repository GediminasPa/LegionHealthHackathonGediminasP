# Copy to .env (bin/init does this for you)

APP_NAME=CopayGuard

# Postgres (docker-compose)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# API
API_PORT=8000

# AI: paste your Grok key to enable the agent endpoint.
# XAI_API_KEY is also accepted.
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
AGENT_MODEL=grok:grok-4.3

# Optional Anthropic fallback: set AGENT_MODEL=anthropic:<model> and this key.
ANTHROPIC_API_KEY=
